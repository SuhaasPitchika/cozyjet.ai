
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile within CozyJet.AI, storing their personal preferences and settings.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "onboarded": { "type": "boolean" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "firstName", "onboarded", "lastLogin", "createdAt", "updatedAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "description": "A single message in the Snooks marketing chat.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "bot"] },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["text", "content"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "role", "content", "type", "createdAt"]
    },
    "ProductivitySession": {
      "title": "ProductivitySession",
      "type": "object",
      "description": "Analysis of a user's productivity generated by Flippo.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "score": { "type": "number" },
        "insights": { "type": "string" },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "time": { "type": "string" },
              "app": { "type": "string" },
              "action": { "type": "string" },
              "type": { "type": "string" },
              "emotion": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "score", "timeline", "createdAt"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Private user profile document."
        }
      },
      {
        "path": "/users/{userId}/snooksMessages/{messageId}",
        "definition": {
          "entityName": "ChatMessage",
          "schema": { "$ref": "#/backend/entities/ChatMessage" },
          "description": "Messages in the Snooks chat."
        }
      },
      {
        "path": "/users/{userId}/productivitySessions/{sessionId}",
        "definition": {
          "entityName": "ProductivitySession",
          "schema": { "$ref": "#/backend/entities/ProductivitySession" },
          "description": "Past productivity sessions analyzed by Flippo."
        }
      }
    ]
  }
}
