
{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user's profile and security context.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "passkeyId": { "type": "string", "description": "WebAuthn credential ID for KDF input." },
        "settings": { "type": "string" }
      },
      "required": ["id", "email", "passkeyId"]
    },
    "Integration": {
      "title": "Integration",
      "type": "object",
      "description": "Connected workspaces (Notion, Figma, GitHub) monitored by SKIPPY.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "type": { "type": "string", "enum": ["notion", "figma", "github"] },
        "status": { "type": "string" },
        "lastSyncAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "type", "status"]
    },
    "ContentDraft": {
      "title": "ContentDraft",
      "type": "object",
      "description": "Marketing content generated locally by SKIPPY, pending approval.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "platform": { "type": "string" },
        "body": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "approved", "published"] },
        "complianceStatus": { "type": "string" },
        "scheduledAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "platform", "body", "status"]
    },
    "ComplianceReport": {
      "title": "ComplianceReport",
      "type": "object",
      "description": "Aggregated safety checks performed by SNOOKS at the edge.",
      "properties": {
        "id": { "type": "string" },
        "draftId": { "type": "string" },
        "overallStatus": { "type": "string" },
        "checkResults": { "type": "string", "description": "JSON string of the 7 compliance checks." }
      },
      "required": ["id", "draftId", "overallStatus", "checkResults"]
    },
    "AuditLog": {
      "title": "AuditLog",
      "type": "object",
      "description": "Cryptographically linked audit trail of security actions.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "hash": { "type": "string" },
        "prevHash": { "type": "string" }
      },
      "required": ["id", "userId", "action", "timestamp", "hash", "prevHash"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Root user profile."
        }
      },
      {
        "path": "/users/{userId}/integrations/{id}",
        "definition": {
          "entityName": "Integration",
          "schema": { "$ref": "#/backend/entities/Integration" },
          "description": "Connected workspace integrations."
        }
      },
      {
        "path": "/users/{userId}/drafts/{id}",
        "definition": {
          "entityName": "ContentDraft",
          "schema": { "$ref": "#/backend/entities/ContentDraft" },
          "description": "Generated content variations."
        }
      },
      {
        "path": "/users/{userId}/complianceReports/{id}",
        "definition": {
          "entityName": "ComplianceReport",
          "schema": { "$ref": "#/backend/entities/ComplianceReport" },
          "description": "Compliance scan results."
        }
      },
      {
        "path": "/users/{userId}/auditLogs/{id}",
        "definition": {
          "entityName": "AuditLog",
          "schema": { "$ref": "#/backend/entities/AuditLog" },
          "description": "Security audit trail."
        }
      }
    ]
  }
}
