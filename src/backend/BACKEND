// src/backend/types.ts

export interface AgentConfig {
  id: string;
  name: string;
  description?: string;
  model?: string;
  temperature?: number;
  maxSteps?: number;
  maxRetries?: number;
  capabilities: string[];
}

export interface TaskContext {
  taskId: string;
  userId: string;
  agentId: string;
  parameters: Record<string, any>;
  createdAt: Date;
  status: 'pending' | 'running' | 'completed' | 'failed';
  metadata?: Record<string, any>;
}

export interface ExecutionResult<T = any> {
  success: boolean;
  taskId: string;
  agentId: string;
  result?: T;
  error?: string;
  executionTime: number;
  completedAt: Date;
  steps: ExecutionStep[];
}

export interface ExecutionStep {
  stepNumber: number;
  action: string;
  input?: any;
  output?: any;
  error?: string;
  duration: number;
  timestamp: Date;
}

export interface Tool {
  id: string;
  name: string;
  description: string;
  inputSchema: Record<string, any>;
  execute(input: any): Promise<any>;
}

export interface ConversationMessage {
  id: string;
  conversationId: string;
  role: 'user' | 'assistant' | 'system';
  content: string;
  timestamp: Date;
  metadata?: Record<string, any>;
}

export interface WorkCompletion {
  id: string;
  userId: string;
  workSummary: string;
  workType: string;
  timestamp: Date;
  duration: number;
  flowScore?: number;
  integrationSource?: string;
}

export interface ContentGenerationRequest {
  userId: string;
  workSummary?: string;
  topic?: string;
  platform: 'linkedin' | 'twitter' | 'instagram' | 'youtube' | 'tiktok';
  contentType: 'thread' | 'article' | 'carousel' | 'script';
  style?: string;
  maxLength?: number;
}

export interface GeneratedContent {
  id: string;
  userId: string;
  platform: string;
  contentType: string;
  content: string[];
  hook: string;
  callToAction: string;
  estimatedEngagement?: number;
  createdAt: Date;
}
