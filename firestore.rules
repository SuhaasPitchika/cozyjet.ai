rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict user-ownership model for all application data. 
     * Security is achieved through hierarchical pathing and data denormalization 
     * to ensure that users can only access their own records without requiring 
     * expensive cross-document lookups.
     *
     * DATA STRUCTURE:
     * Almost all application data (profiles, sessions, conversations, messages) 
     * is nested under the path /users/{userId}. This creates a clear physical 
     * boundary for user data.
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Critical fields like 'userId' or parent IDs 
     *    are denormalized into subcollection documents. This allows for flat 
     *    authorization checks directly on the document being accessed.
     * 2. Public vs. Private: The /waitlistSubscribers collection is publicly 
     *    writable to allow new sign-ups but strictly unreadable by clients.
     * 3. Immutability: Relational fields that establish ownership (e.g., userId, 
     *    sessionId) are enforced as immutable during updates to prevent 
     *    unauthorized data re-assignment.
     */

    // --- Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks ownership and ensures the document exists for destructive operations. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    // --- Collection Rules ---

    /**
     * @description Rules for the root UserProfile document.
     * @path /users/{userId}
     * @allow (create) if auth.uid matches the path userId.
     * @deny (list) if auth.uid does not match the path userId.
     * @principle Self-creation and strict ownership for the user's primary identity.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update, delete: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;

      /**
       * @description Stores encrypted screen analysis data blobs.
       * @path /users/{userId}/skippyEncryptedData/{dataId}
       * @allow (create) if the owner creates a record linked to their userId.
       * @deny (update) if an attempt is made to change the owning userId.
       * @principle Ensures private blobs are only accessible to the account owner.
       */
      match /skippyEncryptedData/{dataId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Summaries of work sessions generated by Flippo AI.
       * @path /users/{userId}/productivitySessions/{sessionId}
       * @allow (get) for the owner of the session.
       * @deny (create) if the userId in the data does not match the path.
       * @principle Path-based authorization mirrored in internal document fields.
       */
      match /productivitySessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Individual activity blocks within a session.
         * @path /users/{userId}/productivitySessions/{sessionId}/timelineEntries/{entryId}
         * @allow (list) for the owner of the parent productivity session.
         * @deny (create) if the sessionId in data doesn't match the parent path.
         * @principle Validates relational integrity within nested hierarchies.
         */
        match /timelineEntries/{entryId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.sessionId == sessionId;
          allow update: if isExistingOwner(userId) && request.resource.data.sessionId == resource.data.sessionId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Conversation threads with the Snooks AI agent.
       * @path /users/{userId}/snooksConversations/{conversationId}
       * @allow (update) for the owner of the conversation.
       * @deny (delete) for a different user.
       * @principle Enforces strict ownership over AI interaction history.
       */
      match /snooksConversations/{conversationId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Individual messages within a conversation.
         * @path /users/{userId}/snooksConversations/{conversationId}/snooksMessages/{messageId}
         * @allow (get) if the owner views the message.
         * @deny (create) if the conversationId link is tampered with.
         * @principle Relational integrity for nested messaging components.
         */
        match /snooksMessages/{messageId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.conversationId == conversationId;
          allow update: if isExistingOwner(userId) && request.resource.data.conversationId == resource.data.conversationId;
          allow delete: if isExistingOwner(userId);

          /**
           * @description Marketing content generated based on a specific message.
           * @path /users/{userId}/snooksConversations/{conversationId}/snooksMessages/{messageId}/generatedContentOutputs/{outputId}
           * @allow (create) for the owner of the message trail.
           * @deny (update) if the messageId reference is changed.
           * @principle Protects generated assets through hierarchical ownership.
           */
          match /generatedContentOutputs/{outputId} {
            allow get, list: if isOwner(userId);
            allow create: if isOwner(userId) && request.resource.data.messageId == messageId;
            allow update: if isExistingOwner(userId) && request.resource.data.messageId == resource.data.messageId;
            allow delete: if isExistingOwner(userId);
          }
        }
      }
    }

    /**
     * @description Waitlist collection for new user sign-ups.
     * @path /waitlistSubscribers/{subscriberId}
     * @allow (create) for any visitor (public write).
     * @deny (read/update/delete) for all client-side requests.
     * @principle Public intake with administrative-only retrieval.
     */
    match /waitlistSubscribers/{subscriberId} {
      allow create: if true;
      allow get, list, update, delete: if false;
    }
  }
}