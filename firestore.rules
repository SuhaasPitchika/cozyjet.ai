rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * COZYJET.AI SECURITY RULES
     * 
     * CORE PHILOSOPHY:
     * This ruleset implements a strict user-ownership model combined with administrative role-based access 
     * control (RBAC). It prioritizes "Authorization Independence" by using path-based wildcards and 
     * document existence checks to minimize complex cross-document lookups.
     * 
     * DATA STRUCTURE:
     * - /users/{userId}: Private user profiles and activity data.
     * - /users/{userId}/contentOutputs: Private AI-generated marketing content.
     * - /users/{userId}/productivitySessions: Private work session analytics.
     * - /waitlistEntries: Publicly writable collection for lead generation; admin-only reads.
     * - /testimonials: Publicly readable (if visible); admin-managed content.
     * - /roles_admin: Internal collection where document existence grants administrative privileges.
     * 
     * KEY SECURITY DECISIONS:
     * 1. Path-Based Authorization: Most user data is nested under /users/{userId}, allowing rules to 
     *    instantly verify ownership by comparing the path wildcard to the request.auth.uid.
     * 2. Administrative RBAC: An 'isAdmin' helper checks the /roles_admin collection. Admins have 
     *    elevated access to waitlists and testimonials.
     * 3. Structural Segregation: Publicly writable data (waitlist) is kept in a top-level collection 
     *    separate from private user data to prevent accidental exposure.
     * 4. Relational Integrity: On creation and update, rules enforce that internal data fields (like userId) 
     *    match the authenticated user or the document path to maintain database consistency.
     */

    // --- Global Helper Functions ---

    /** @description Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided ID. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if a document exists and the user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    /** @description Checks if the authenticated user has an entry in the admin roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    /** @description Checks if a document exists and the user is an admin. */
    function isExistingAdmin() {
      return resource != null && isAdmin();
    }

    // --- Collection Rules ---

    /**
     * @description Rules for individual user profiles and settings.
     * @path /users/{userId}
     * @allow (get, update) if the user's UID matches {userId}.
     * @deny (list) to prevent user enumeration.
     * @principle Ownership and Relational Integrity.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users should not be able to list other users.
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for marketing content generated by the Snooks AI agent.
       * @path /users/{userId}/contentOutputs/{contentOutputId}
       * @allow (create, read, update, delete) if the user's UID matches {userId}.
       * @deny (any) if the user is not the owner of the parent path.
       * @principle Path-based ownership.
       */
      match /contentOutputs/{contentOutputId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Records of productivity sessions and deep work scores.
       * @path /users/{userId}/productivitySessions/{sessionId}
       * @allow (create, read, update, delete) if the user's UID matches {userId}.
       * @deny (any) if the user is not the owner.
       * @principle Path-based ownership.
       */
      match /productivitySessions/{sessionId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Waitlist signups. Publicly writable, Admin readable.
     * @path /waitlistEntries/{entryId}
     * @allow (create) for anyone to sign up.
     * @allow (read, delete) only for administrators.
     * @principle Structural Segregation (Public Write / Admin Read).
     */
    match /waitlistEntries/{entryId} {
      allow get, list: if isAdmin();
      allow create: if true; // Publicly accessible for new entries.
      allow update: if isAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Public testimonials for the landing page.
     * @path /testimonials/{testimonialId}
     * @allow (get, list) if the testimonial is marked 'isVisible'.
     * @allow (write) only for administrators.
     * @principle Public Read with Admin-Only Writes.
     */
    match /testimonials/{testimonialId} {
      allow get: if resource.data.isVisible == true || isAdmin();
      allow list: if resource.data.isVisible == true || isAdmin();
      allow create: if isAdmin();
      allow update: if isExistingAdmin();
      allow delete: if isExistingAdmin();
    }

    /**
     * @description Internal collection defining administrative privileges.
     * @path /roles_admin/{adminId}
     * @allow (get) if the user is an admin.
     * @deny (write, list) to all client-side requests (managed via Admin SDK or system).
     * @principle DBAC (Database Access Control).
     */
    match /roles_admin/{adminId} {
      allow get: if isSignedIn() && (request.auth.uid == adminId || isAdmin());
      allow list: if isAdmin();
      allow create, update, delete: if false; // Strictly managed via backend/admin tools.
    }
  }
}