NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN = "studio-9941557236-b9262.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID = "326839652598"

[userenv.development]

[userenv.production]
